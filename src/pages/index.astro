      .process-item:hover .item-inner {
        transform: translateY(-8px);
        border-color: var(--yellow);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.06);
      }

      .icon-wrap {
        position: relative;
        width: 80px;
        height: 80px;
        background-color: var(--paper);
