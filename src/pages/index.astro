        display: grid;
        place-items: center;
        font-size: 30px;
        color: var(--yellow-hover);
        margin-bottom: 30px;
        transition: all 300ms ease;
      }

      .process-item:hover .icon-wrap {
        background-color: var(--yellow);
        color: var(--black);
      }

      .step-num {
        position: absolute;
        top: -5px;
        right: -5px;
        width: 28px;
        height: 28px;
        background-color: var(--black);
        color: var(--white);
        font-family: var(--font-display);
        font-size: 11px;
        font-weight: 700;
        border-radius: 999px;
        display: grid;
        place-items: center;
      }

      .process-item h3 {
        font-family: var(--font-display);
        font-size: 20px;
        font-weight: 700;
        margin-bottom: 15px;
      }

      .process-item p {
        font-size: 14px;
        color: var(--ink-soft);
        line-height: 1.6;
      }

      /* Portfolio Area */
      .portfolio-area {
        background-color: var(--black);
      }

      .portfolio-box {
        margin-top: 50px;
        position: relative;
      }

      .portfolio-item {
        background-color: var(--dark-card);
        border-radius: 4px;
        overflow: hidden;
      }

      .portfolio-item .thumb {
        position: relative;
        overflow: hidden;
        aspect-ratio: 4 / 3;
      }

      .portfolio-item .thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 500ms ease;
      }

      .portfolio-item:hover .thumb img {
        transform: scale(1.05);
      }

      .portfolio-item .overlay {
        position: absolute;
        inset: 0;
        background-color: rgba(18, 20, 24, 0.7);
        display: grid;
        place-items: center;
        opacity: 0;
        transition: opacity 300ms ease;
      }

      .portfolio-item:hover .overlay {
        opacity: 1;
      }

      .image-zoom-btn {
        width: 50px;
        height: 50px;
        border-radius: 999px;
        border: 0;
        background-color: var(--yellow);
        color: var(--black);
        font-size: 16px;
        cursor: pointer;
        display: grid;
        place-items: center;
        transition: transform 250ms ease;
      }

      .image-zoom-btn:hover {
        transform: scale(1.1);
      }

      .portfolio-item .info {
        padding: 24px;
      }

      .portfolio-item .info h3 {
        font-family: var(--font-display);
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 6px;
        color: var(--white);
      }

      .portfolio-item .info h3 a:hover {
        color: var(--yellow);
      }

      .portfolio-item .info span {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.5);
        text-transform: uppercase;
        font-weight: 600;
        letter-spacing: 0.5px;
      }

      .portfolio-box {
        position: relative;
      }

      .portfolio-prev,
      .portfolio-next {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        width: 44px;
        height: 44px;
        background: transparent;
        border: 0;
        color: var(--yellow);
        font-size: 30px;
        cursor: pointer;
        z-index: 10;
        margin: 0;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 250ms ease;
      }

      .portfolio-prev {
        left: -50px;
      }

      .portfolio-next {
        right: -50px;
      }

      .portfolio-prev:hover,
      .portfolio-next:hover {
        color: var(--white);
      }

      .portfolio-prev::after,
      .portfolio-next::after {
        display: none !important;
      }

      @media (max-width: 1200px) {
        .portfolio-prev {
          left: 10px;
        }
        .portfolio-next {
          right: 10px;
        }
      }

      /* Team Section */
      .team-area {
        background-color: var(--white);
        overflow: hidden;
      }

      .team-items {
        margin-top: 50px;
      }

      .team-item {
        background-color: var(--paper);
        border-radius: 4px;
        overflow: hidden;
      }

      .team-item .thumb {
        position: relative;
        overflow: hidden;
        aspect-ratio: 3 / 4;
      }

      .team-item .thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .team-item .info {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        background-image: linear-gradient(to top, rgba(18, 20, 24, 0.9), transparent);
        padding: 30px 20px 20px;
        color: var(--white);
        transition: transform 300ms ease, opacity 300ms ease;
      }

      .team-item:hover .info {
        transform: translateY(20px);
        opacity: 0;
      }

      .team-item .info h4 {
        font-family: var(--font-display);
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 2px;
      }

      .team-item .info span {
        font-size: 13px;
        color: var(--yellow);
      }

      .team-item .overlay {
        position: absolute;
        inset: 0;
        background-color: rgba(18, 20, 24, 0.92);
        padding: 40px 30px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        opacity: 0;
        transition: opacity 300ms ease;
      }

      .team-item:hover .overlay {
        opacity: 1;
      }

      .team-item .overlay h4 {
        font-family: var(--font-display);
        font-size: 20px;
        font-weight: 700;
        color: var(--yellow);
        margin-bottom: 12px;
      }

      .team-item .overlay p {
        font-size: 14px;
        color: rgba(255, 255, 255, 0.85);
        line-height: 1.6;
      }

      .team-item .social {
        padding: 15px 20px;
        border-top: 1px solid var(--line);
        background-color: var(--white);
      }

      .team-item .social ul {
        list-style: none;
        display: flex;
        justify-content: center;
        gap: 20px;
      }

      .team-item .social a {
        color: var(--ink-soft);
        font-size: 14px;
      }

      .team-item .social a:hover {
        color: var(--yellow);
      }

      .team-items {
        position: relative;
        margin-top: 50px;
      }



      .team-area .fixed-shape {
        position: absolute;
        left: 0;
        bottom: 0;
        z-index: -1;
        opacity: 0.05;
        width: 25%;
      }

      /* Testimonials Section */
      .testimonials-area {
        background-color: var(--paper);
      }

      .testimonial-grid {
        display: grid;
        grid-template-columns: 1.2fr 1.8fr;
        gap: 60px;
        align-items: center;
      }

      .title-column h2 {
        font-family: var(--font-display);
        font-size: clamp(28px, 4.2vw, 40px);
        font-weight: 800;
        line-height: 1.2;
        margin: 8px 0 20px;
