---
import 'swiper/css/bundle';
import '@fortawesome/fontawesome-free/css/all.min.css';
import 'animate.css/animate.min.css';


const serviceTabs = [
  { id: 'construction', label: 'Construction', title: 'Construction of public works based on general planning, instruction, and control', image: '/assets/photos/service-1.jpg' },
  { id: 'power', label: 'Power & Energy', title: 'In physics we say that work is done on an object when you transfer energy.', image: '/assets/photos/service-2.jpg' },
  { id: 'building', label: 'Building Industry', title: 'Construction is a general term meaning the art and science to form objects', image: '/assets/photos/service-3.jpg' },
  { id: 'mechanical', label: 'Mechanical', title: 'Mechanical engineering is an engineering branch that combines engineering.', image: '/assets/photos/service-4.jpg' },
];

const processSteps = [
  { step: '01', title: 'Design', icon: 'flaticon-ruler', text: 'Our engineers turn your specifications into detailed CAD drawings, load calculations, and material schedules before a single component is fabricated.' },
  { step: '02', title: 'Planning', icon: 'flaticon-creativity', text: 'We sequence procurement, logistics, and on-site labor into a fixed timeline with clear milestones, safety reviews, and budget checkpoints.' },
  { step: '03', title: 'Development', icon: 'flaticon-house', text: 'Certified crews fabricate, assemble, and commission your project to ISO standards, with quality inspections at every stage through final handover.' },
];

const portfolioItems = [
  { title: 'Oil & Gas Energy', category: 'industry, environment', image: '/assets/photos/project-1.jpg' },
  { title: 'Agriculture Automation', category: 'industry, environment', image: '/assets/photos/project-2.jpg' },
  { title: 'Civil Engineering', category: 'industry, environment', image: '/assets/photos/project-3.jpg' },
  { title: 'Bridge Construction', category: 'industry, environment', image: '/assets/photos/project-4.jpg' },
];

const teamItems = [
  { name: 'Jessica Jones', role: 'Founder & CEO', image: '/assets/photos/team-1.jpg', text: 'Three decades building industrial plants across the West Coast, leading Factoria with a safety-first, on-time delivery standard.' },
  { name: 'Munia Ankor', role: 'Lead Structural Engineer', image: '/assets/photos/team-2.jpg', text: 'Oversees structural design and load engineering, ensuring every build meets seismic and OSHA code requirements.' },
  { name: 'Ahmed Kamal', role: 'Operations Officer', image: '/assets/photos/team-3.jpg', text: 'Runs field operations and logistics, coordinating crews, equipment, and suppliers across concurrent project sites.' },
];

const testimonialItems = [
  { name: 'Jones Adhor', role: 'Architect', image: '/assets/photos/testimonial-1.jpg', text: 'Factoria delivered our processing facility two weeks ahead of schedule and on budget. Their crews were professional, safety-conscious, and meticulous from planning through handoff.' },
  { name: 'Mones Basel', role: 'Designer', image: '/assets/photos/testimonial-2.jpg', text: 'From early planning to commissioning, Factoria handled every detail with discipline. The build quality and communication gave our team real confidence.' },
];

const blogItems = [
  { title: 'How modern prefabrication is cutting industrial build timelines in half.', date: '12 Nov, 2026', author: 'Factoria', authorImg: '/assets/photos/team-1.jpg', image: '/assets/photos/blog-1.jpg' },
  { title: 'Five safety standards every construction partner should meet in 2026.', date: '08 Aug, 2026', author: 'Factoria', authorImg: '/assets/photos/team-2.jpg', image: '/assets/photos/blog-2.jpg' },
  { title: 'Sustainable materials reshaping heavy industry and plant construction.', date: '25 Jun, 2026', author: 'Factoria', authorImg: '/assets/photos/team-3.jpg', image: '/assets/photos/blog-3.jpg' },
];

---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/brand/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/brand/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/assets/brand/favicon.png" />
    
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Factoria - Factory, Industrial & Construction Premium Rebuild" />
    <title>Factoria | Factory & Construction</title>
  </head>
  <body>
    <!-- Top Contact Bar -->
    <div class="header-top">
      <div class="container top-grid">
        <ul class="top-left">
          <li><i class="fas fa-phone"></i> <b>Call Us:</b> <a href="tel:+1234567890">+123 456 7890</a></li>
          <li><i class="fas fa-envelope"></i> <b>Email:</b> <a href="mailto:hello@factoria.build">hello@factoria.build</a></li>
          <li><i class="fas fa-map-marker-alt"></i> California, TX 70240</li>
        </ul>
        <div class="social-style-one" aria-label="Social links">
          <a href="#top" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
          <a href="#top" aria-label="Twitter"><i class="fab fa-x-twitter"></i></a>
          <a href="#top" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a>
          <a href="#top" aria-label="Behance"><i class="fab fa-behance"></i></a>
        </div>
      </div>
    </div>

    <!-- Navigation Header -->
    <header class="main-header" aria-label="Primary navigation">
      <div class="container header-inner">
        <a class="logo" href="#top" aria-label="Factoria Home">
          <img src="/assets/brand/logo_white.png" class="logo-display" alt="Factoria" width="296" height="54" />
          <img src="/assets/brand/logo.png" class="logo-scrolled" alt="Factoria" width="296" height="54" />
        </a>
        
        <button class="menu-toggle" type="button" aria-label="Toggle navigation" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>

        <nav class="main-menu" id="navbar-menu">
          <ul class="navigation">
            <li class="dropdown">
              <a href="#top">Home <i class="fas fa-angle-down"></i></a>
              <ul class="dropdown-menu">
                <li><a href="#top">Home Version One</a></li>
                <li><a href="#top">Home Version Two</a></li>
                <li><a href="#top">Home Version Three</a></li>
                <li><a href="#top">Home Version Four</a></li>
              </ul>
            </li>
            <li class="dropdown">
              <a href="#about">Pages <i class="fas fa-angle-down"></i></a>
              <ul class="dropdown-menu">
                <li><a href="#about">About Us</a></li>
                <li><a href="#footer-contact">Contact Us</a></li>
                <li><a href="#top">Faq</a></li>
                <li><a href="#top">Error Page</a></li>
              </ul>
            </li>
            <li class="dropdown megamenu-fw">
              <a href="#portfolio">Projects <i class="fas fa-angle-down"></i></a>
              <div class="dropdown-menu megamenu-content">
                <div class="container">
                  <div class="row">
                    <div class="col-menu col-lg-3 col-md-6">
                      <h6 class="title">Masonary Colum</h6>
                      <ul class="menu-col">
                        <li><a href="#portfolio">Masonary Two Colums</a></li>
                        <li><a href="#portfolio">Masonary Three Colums</a></li>
                        <li><a href="#portfolio">Masonary Four Colums</a></li>
                      </ul>
                    </div>
                    <div class="col-menu col-lg-3 col-md-6">
                      <h6 class="title">Grid Colum</h6>
                      <ul class="menu-col">
                        <li><a href="#portfolio">Grid Two Colums</a></li>
                        <li><a href="#portfolio">Grid Three Colums</a></li>
                        <li><a href="#portfolio">Grid Four Colums</a></li>
                      </ul>
                    </div>
                    <div class="col-menu col-lg-3 col-md-6">
                      <h6 class="title">Additional Version</h6>
                      <ul class="menu-col">
                        <li><a href="#portfolio">Project Carousel</a></li>
                        <li><a href="#portfolio">Project Details</a></li>
                      </ul>
                    </div>
                    <div class="col-menu col-lg-3 col-md-6">
                      <h6 class="title">Additional Pages</h6>
                      <ul class="menu-col">
                        <li><a href="#top">Login</a></li>
                        <li><a href="#top">Register</a></li>
                      </ul>
                    </div>
                  </div>
                </div>
              </div>
            </li>
            <li class="dropdown">
              <a href="#services">Services <i class="fas fa-angle-down"></i></a>
              <ul class="dropdown-menu">
                <li><a href="#services">Services Version One</a></li>
                <li><a href="#services">Services Version Two</a></li>
                <li><a href="#services">Services Version Three</a></li>
                <li><a href="#services">Services Details</a></li>
              </ul>
            </li>
            <li class="dropdown">
              <a href="#team">Team <i class="fas fa-angle-down"></i></a>
              <ul class="dropdown-menu">
                <li><a href="#team">Team Grid</a></li>
                <li><a href="#team">Team Carousel</a></li>
              </ul>
            </li>
            <li class="dropdown">
              <a href="#blog">Blog <i class="fas fa-angle-down"></i></a>
              <ul class="dropdown-menu">
                <li><a href="#blog">Blog Standard</a></li>
                <li><a href="#blog">Blog With Sidebar</a></li>
                <li><a href="#blog">Blog Grid Two Colum</a></li>
                <li><a href="#blog">Blog Grid Three Colum</a></li>
                <li><a href="#blog">Blog Single</a></li>
              </ul>
            </li>
            <li><a href="#footer-contact">Contact Us</a></li>
          </ul>
        </nav>

        <div class="attr-nav">
          <button class="search-btn" aria-label="Search"><i class="fas fa-search"></i></button>
          <a class="theme-btn" href="#footer-contact">get a quote</a>
        </div>
      </div>
    </header>

    <!-- Global Fullscreen Search Overlay -->
    <div class="search-overlay">
      <button class="close-search" aria-label="Close search"><i class="fas fa-times"></i></button>
      <div class="search-form-wrap">
        <form role="search" method="get" action="#">
          <input type="search" class="search-field" placeholder="Search..." name="s" autocomplete="off" />
          <button type="submit" class="search-submit" aria-label="Submit search"><i class="fas fa-search"></i></button>
        </form>
      </div>
    </div>

    <main id="top">
      <!-- Hero Slider -->
      <section class="hero-area" aria-label="Hero slider">
        <div class="swiper hero-slider">
          <div class="swiper-wrapper">
            <!-- Slide 1 -->
            <div class="swiper-slide">
              <img src="/assets/photos/hero-factory-2.jpg" alt="Advanced technology" class="slider-thumb" />
              <div class="slider-overlay"></div>
              <div class="slide-content-wrap">
                <div class="container">
                  <div class="slide-text">
                    <h1>Advanced <strong>technology</strong></h1>
                    <p>
                      From heavy civil works to full plant construction, Factoria delivers industrial projects on time, on budget, and to the highest safety standards — backed by 35 years of engineering experience.
                    </p>
                    <div class="slide-btns">
                      <a class="theme-btn" href="#portfolio">View Projects <i class="fas fa-arrow-right"></i></a>
                      <button class="video-play-btn video-play" data-video="https://www.youtube.com/embed/9Y7ma241N8k" aria-label="Play video"><i class="fas fa-play"></i></button>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <!-- Slide 2 -->
            <div class="swiper-slide">
              <img src="/assets/photos/hero-factory-2.jpg" alt="Advanced Machinery" class="slider-thumb" />
              <div class="slider-overlay"></div>
              <div class="slide-content-wrap">
                <div class="container">
                  <div class="slide-text">
                    <h1>Advanced <strong>Machinery</strong></h1>
                    <p>
                      Our fabrication shops and field crews run modern, well-maintained equipment so your build moves faster, safer, and with the precision heavy industry demands.
                    </p>
                    <div class="slide-btns">
                      <a class="theme-btn" href="#portfolio">View Projects <i class="fas fa-arrow-right"></i></a>
                      <button class="video-play-btn video-play" data-video="https://www.youtube.com/embed/9Y7ma241N8k" aria-label="Play video"><i class="fas fa-play"></i></button>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <!-- Slider Navigation -->
          <button class="hero-prev" aria-label="Previous slide"><i class="fa-solid fa-angle-left"></i></button>
          <button class="hero-next" aria-label="Next slide"><i class="fa-solid fa-angle-right"></i></button>
        </div>
      </section>

      <!-- About Section -->
      <section class="about-area" id="about" aria-labelledby="about-heading">
        <div class="container">
          <div class="about-box">
            <div class="about-grid">
              <div class="about-image wow animate__animated animate__fadeInLeft">
                <img src="/assets/photos/service-1.jpg" alt="Industrial engineering experience" />
                <div class="experience-badge">
                  <span class="exp-num">25</span>
                  <span class="exp-txt">Years Work experience in construction</span>
                </div>
              </div>
              <div class="about-info wow animate__animated animate__fadeInRight">
                <h2 id="about-heading">Contractors & Construction Managers Since 1989</h2>
                <blockquote>
                  <p>
                    Since 1989 we have delivered factories, processing plants, and civil infrastructure across the West Coast. Our reputation is built on disciplined project management, certified crews, and a safety record we are proud of.
                  </p>
                  <cite>Founder of <strong>Factoria</strong></cite>
                </blockquote>
              </div>
            </div>
          </div>
        </div>
        <!-- Background decorative shape -->
        <div class="shape-bg" aria-hidden="true">
          <img src="/assets/img/shape/5.svg" alt="" />
        </div>
      </section>

      <!-- Working With Us CTA / Counter Section -->
      <section class="work-with-us-area">
        <div class="container">
          <div class="content-box">
            <div class="cta-grid">
              <div class="heading-info wow animate__animated animate__fadeInLeft">
                <span class="section-tag">Working with Us</span>
                <h2>Contractors & Construction Managers Since 1989</h2>
                <a href="#footer-contact" class="theme-btn">Get a Quote <i class="fas fa-arrow-right"></i></a>
              </div>
              <div class="fun-facts-items wow animate__animated animate__fadeInRight">
                <div class="facts-grid">
                  <div class="fun-fact">
                    <div class="timer" data-to="16" data-speed="2000">0</div>
                    <h4>Ongoing Projects</h4>
                  </div>
                  <div class="fun-fact">
                    <div class="timer" data-to="32" data-speed="2000">0</div>
                    <h4>End Project</h4>
                  </div>
                  <div class="fun-fact">
                    <div class="timer" data-to="11" data-speed="2000">0</div>
                    <h4>Upcoming Project</h4>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Services Section (Tabs layout) -->
      <section class="service-area" id="services" aria-labelledby="services-heading">
        <div class="container">
          <div class="section-header text-center">
            <span class="section-tag">Our Services</span>
            <h2 id="services-heading">Construction & Industry Services</h2>
          </div>
          <div class="services-box">
            <div class="services-grid">
              <div class="services-nav">
                <div class="nav flex-column nav-pills" id="v-pills-tab" role="tablist" aria-orientation="vertical">
                  {serviceTabs.map((tab, idx) => (
                    <button class={`nav-link ${idx === 0 ? 'active' : ''}`} id={`v-pills-${tab.id}-tab`} data-bs-toggle="pill" data-bs-target={`#v-pills-${tab.id}`} type="button" role="tab" aria-controls={`v-pills-${tab.id}`} aria-selected={idx === 0 ? 'true' : 'false'}>
                      <i class="fas fa-angle-right"></i> {tab.label}
                    </button>
                  ))}
                </div>
              </div>
              <div class="services-content">
                <div class="tab-content" id="v-pills-tabContent">
                  {serviceTabs.map((tab, idx) => (
                    <div class={`tab-pane fade ${idx === 0 ? 'show active' : ''}`} id={`v-pills-${tab.id}`} role="tabpanel" aria-labelledby={`v-pills-${tab.id}-tab`} tabindex="0">
                      <div class="tab-pane-grid">
                        <div class="info">
                          <h3>{tab.title}</h3>
                          <p>
                            Certified teams deliver construction, power, and mechanical works from feasibility and design through fabrication and commissioning. We manage every phase to spec, on schedule, and to code — with safety and quality built into each milestone.
                          </p>
                          <a class="btn-simple" href="#footer-contact">Read More <i class="fas fa-angle-right"></i></a>
                        </div>
                        <div class="thumb">
                          <img src={tab.image} alt={tab.label} />
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Work Process Section -->
      <section class="work-process-area" aria-labelledby="process-heading">
        <div class="container">
          <div class="section-header text-center">
            <span class="section-tag">How we work</span>
            <h2 id="process-heading">Work Process</h2>
            <p class="section-desc">
              A clear, milestone-driven process keeps your project transparent from the first drawing to final handover — no surprises, no scope creep, no missed deadlines.
            </p>
          </div>
          <div class="work-pro-items">
            <div class="process-grid">
              {processSteps.map((step) => (
                <div class="process-item item wow animate__animated animate__fadeInUp">
                  <div class="item-inner">
                    <i class={step.icon}></i>
                    <h4>{step.title} <span>{step.step}</span></h4>
                    <p>{step.text}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- Portfolio Section -->
      <section class="portfolio-area" id="portfolio" aria-labelledby="portfolio-heading">
        <div class="container">
          <div class="section-header text-center text-white">
            <span class="section-tag">Portfolio</span>
            <h2 id="portfolio-heading">Latest Work</h2>
            <p class="section-desc text-white-50">
              A selection of recent industrial and civil projects — energy, agriculture, infrastructure, and heavy construction delivered across the region.
            </p>
          </div>
          <div class="portfolio-box">
            <div class="swiper portfolio-carousel">
              <div class="swiper-wrapper">
                {portfolioItems.map((item) => (
                  <div class="swiper-slide">
                    <div class="portfolio-item">
                      <div class="thumb">
                        <img src={item.image} alt={item.title} />
                        <div class="overlay">
                          <button class="image-zoom-btn" data-image={item.image} aria-label="Zoom image"><i class="fas fa-plus"></i></button>
                        </div>
                      </div>
                      <div class="info">
                        <h3><a href="#portfolio">{item.title}</a></h3>
                        <span>{item.category}</span>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
            <button class="portfolio-prev" aria-label="Previous work"><i class="fa-solid fa-angle-left"></i></button>
            <button class="portfolio-next" aria-label="Next work"><i class="fa-solid fa-angle-right"></i></button>
          </div>
        </div>
      </section>

      <!-- Team Area -->
      <section class="team-area" id="team" aria-labelledby="team-heading">
        <div class="container">
          <div class="section-header text-center">
            <span class="section-tag">Meet our experts</span>
            <h2 id="team-heading">Team Members</h2>
            <p class="section-desc">
              Engineers, project managers, and field leaders who bring decades of combined experience to every Factoria build.
            </p>
          </div>
          <div class="team-items text-center">
            <div class="row">
              {teamItems.map((item) => (
                <div class="col-lg-4 col-md-6 single-item">
                  <div class="team-item">
                    <div class="thumb">
                      <img src={item.image} alt={item.name} />
                      <div class="info">
                        <h4>{item.name}</h4>
                        <span>{item.role}</span>
                      </div>
                      <div class="overlay text-light">
                        <h4>{item.name}</h4>
                        <p>{item.text}</p>
                      </div>
                    </div>
                    <div class="social">
                      <ul>
                        <li><a href="#team" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a></li>
                        <li><a href="#team" aria-label="Twitter"><i class="fab fa-x-twitter"></i></a></li>
                        <li><a href="#team" aria-label="Instagram"><i class="fab fa-instagram"></i></a></li>
                      </ul>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
        <div class="fixed-shape" aria-hidden="true">
          <img src="/assets/img/shape/4.svg" alt="" />
        </div>
      </section>

      <!-- Testimonials Area -->
      <section class="testimonials-area" aria-labelledby="testimonials-heading">
        <div class="container">
          <div class="testimonial-items-wrap">
            <div class="testimonial-grid">
              <div class="title-column wow animate__animated animate__fadeInLeft">
                <h2 id="testimonials-heading">What Customers Say</h2>
                <p>
                  Industrial clients choose Factoria for steady communication, disciplined site management, and build quality that holds up long after handoff.
                </p>
                <a class="theme-btn" href="#portfolio">View All <i class="fas fa-arrow-right"></i></a>
              </div>
              <div class="testimonial-box wow animate__animated animate__fadeInRight">
                <div class="swiper testimonials-carousel">
                  <div class="swiper-wrapper">
                    {testimonialItems.map((item) => (
                      <div class="swiper-slide">
                        <div class="testimonial-item">
                          <p>"{item.text}"</p>
                          <div class="provider">
                            <div class="thumb">
                              <img src={item.image} alt={item.name} />
                            </div>
                            <div class="info">
                              <h5>{item.name}</h5>
                              <span>{item.role}</span>
                            </div>
                          </div>
                        </div>
                      </div>
                    ))}
                  </div>
                  <div class="testimonial-controls">
                    <button class="testimonial-prev" aria-label="Previous review"><i class="fa fa-angle-left"></i></button>
                    <button class="testimonial-next" aria-label="Next review"><i class="fa fa-angle-right"></i></button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Blog Area -->
      <section class="blog-area" id="blog" aria-labelledby="blog-heading">
        <div class="container">
          <div class="section-header text-center">
            <span class="section-tag">Blog</span>
            <h2 id="blog-heading">Latest News</h2>
            <p class="section-desc">
              Insights on construction methods, safety, and sustainable materials from the Factoria engineering team.
            </p>
          </div>
          <div class="blog-items">
            <div class="blog-grid">
              {blogItems.map((item) => (
                <article class="blog-item wow animate__animated animate__fadeInUp">
                  <div class="thumb">
                    <img src={item.image} alt={item.title} />
                  </div>
                  <div class="info">
                    <div class="meta">
                      <ul>
                        <li>
                          <a href="#blog">
                            <img src={item.authorImg} alt={item.author} />
                            <span>{item.author}</span>
                          </a>
                        </li>
                        <li>
                          <i class="fas fa-calendar-alt"></i> {item.date}
                        </li>
                      </ul>
                    </div>
                    <div class="content">
                      <h3><a href="#blog">{item.title}</a></h3>
                      <a class="btn-simple" href="#blog">Read more <i class="fas fa-arrow-right"></i></a>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </div>
      </section>

    </main>

    <!-- Footer -->
    <footer class="main-footer" id="footer-contact">
      <!-- Footer Top contact/newsletter -->
      <div class="footer-top">
        <div class="container footer-top-inner">
          <div class="logo">
            <img src="/assets/brand/logo_white.png" alt="Factoria Logo" width="296" height="54" />
          </div>
          <div class="subscribe-form">
            <form action="#" class="newsletter-form">
              <input type="email" name="email" class="form-control" placeholder="Enter your e-mail here" required autocomplete="off" />
              <button type="submit" aria-label="Subscribe"><i class="fas fa-paper-plane"></i></button>  
            </form>
