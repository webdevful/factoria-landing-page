    <!-- Client-Side Runtime JavaScript -->
    <script>
      import Swiper from 'swiper/bundle';

      // Bootstrap pills custom click handlers
      document.querySelectorAll('[data-bs-toggle="pill"]').forEach((trigger) => {
        trigger.addEventListener('click', () => {
          const targetId = trigger.getAttribute('data-bs-target') || '';
          const targetPane = document.querySelector(targetId);
          if (targetPane) {
            // Remove active/show classes from all sibling pills and panes
            const pillsContainer = trigger.closest('.nav-pills');
            pillsContainer?.querySelectorAll('.nav-link').forEach((pill) => pill.classList.remove('active'));
            trigger.classList.add('active');

            const contentContainer = document.querySelector('#v-pills-tabContent');
            contentContainer?.querySelectorAll('.tab-pane').forEach((pane) => {
              pane.classList.remove('show', 'active');
            });
            targetPane.classList.add('show', 'active');
          }
        });
      });

      // WOW.js initialization fallback
      import('wow.js').then(({ default: WOW }) => {
        const WowConstructor = WOW?.WOW || WOW;
        if (typeof WowConstructor === 'function') {
          new WowConstructor({ boxClass: 'wow', animateClass: 'animate__animated', live: false }).init();
          document.documentElement.dataset.wowRuntime = 'active';
        }
      }).catch(() => {
        document.documentElement.dataset.wowRuntime = 'mapped';
      });

      // Swiper Sliders
      new Swiper('.hero-slider', {
        slidesPerView: 1,
        loop: false,
        rewind: true,
        effect: 'fade',
        fadeEffect: {
          crossFade: true
        },
        autoplay: { delay: 6000, disableOnInteraction: true },
        speed: 1000,
        navigation: { nextEl: '.hero-next', prevEl: '.hero-prev' },
      });

      new Swiper('.portfolio-carousel', {
        slidesPerView: 1,
        spaceBetween: 30,
        rewind: true,
        autoplay: { delay: 5000, disableOnInteraction: true },
        navigation: { nextEl: '.portfolio-next', prevEl: '.portfolio-prev' },
        breakpoints: {
          1000: { slidesPerView: 2 },
        },
      });

      new Swiper('.testimonials-carousel', {
        slidesPerView: 1,
        loop: false,
        rewind: true,
        speed: 700,
        autoplay: { delay: 5000, disableOnInteraction: true },
        navigation: { nextEl: '.testimonial-next', prevEl: '.testimonial-prev' },
        autoHeight: true,
      });

      // High-Performance Counter Animation
      const animateCounters = () => {
        const timers = document.querySelectorAll('.timer');
        timers.forEach((timer) => {
          const target = parseInt(timer.getAttribute('data-to') || '0', 10);
          const duration = parseInt(timer.getAttribute('data-speed') || '2000', 10);
          const startTime = performance.now();

          const updateCounter = (currentTime) => {
            const elapsedTime = currentTime - startTime;
            const progress = Math.min(elapsedTime / duration, 1);
            const currentValue = Math.floor(progress * target);
            
            timer.textContent = String(currentValue);

            if (progress < 1) {
              requestAnimationFrame(updateCounter);
            } else {
              timer.textContent = String(target);
            }
          };

          requestAnimationFrame(updateCounter);
        });
      };

      // Trigger counter when visible
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            animateCounters();
            observer.disconnect();
          }
        });
      }, { threshold: 0.2 });

      const countersSection = document.querySelector('.work-with-us-area');
      if (countersSection) observer.observe(countersSection);

      // Header Fixed & Scroll-To-Top button visibility
      const header = document.querySelector('.main-header');
      const scrollTop = document.querySelector('.scroll-top');

      const updateChrome = () => {
        header?.classList.toggle('fixed-header', window.scrollY > 40);
        scrollTop?.classList.toggle('is-visible', window.scrollY > 450);
      };
      updateChrome();
      window.addEventListener('scroll', updateChrome, { passive: true });

      // Mobile Navigation Menu Toggle
      const menuToggle = document.querySelector('.menu-toggle');
      const mainMenu = document.querySelector('#navbar-menu');

      menuToggle?.addEventListener('click', () => {
        const expanded = menuToggle.getAttribute('aria-expanded') === 'true';
        menuToggle.setAttribute('aria-expanded', String(!expanded));
        mainMenu?.classList.toggle('is-open', !expanded);
      });

      // Mobile Dropdowns Toggle
      document.querySelectorAll('.dropdown > a').forEach((toggle) => {
        toggle.addEventListener('click', (e) => {
          if (window.innerWidth <= 1024) {
            e.preventDefault();
            const parent = toggle.parentElement;
            parent?.classList.toggle('open');
          }
        });
      });

      document.querySelectorAll('.main-menu a').forEach((link) => {
        link.addEventListener('click', (e) => {
          // If this is a dropdown toggle on mobile, do not close the main mobile menu
          if (window.innerWidth <= 1024 && link.parentElement?.classList.contains('dropdown') && link.nextElementSibling?.classList.contains('dropdown-menu')) {
            return;
          }
          menuToggle?.setAttribute('aria-expanded', 'false');
          mainMenu?.classList.remove('is-open');
        });
      });

      // Search Overlay Open/Close
      const searchBtn = document.querySelector('.search-btn');
      const searchOverlay = document.querySelector('.search-overlay');
      const closeSearch = document.querySelector('.close-search');

      searchBtn?.addEventListener('click', () => {
        searchOverlay?.classList.add('is-open');
      });

      closeSearch?.addEventListener('click', () => {
        searchOverlay?.classList.remove('is-open');
      });

      // Scroll to Top action
      scrollTop?.addEventListener('click', () => {
        document.documentElement.style.scrollBehavior = 'auto';
        window.scrollTo(0, 0);
        window.setTimeout(() => {
          document.documentElement.style.scrollBehavior = '';
        }, 50);
      });

      // Video Popup Modal Action
      const videoModal = document.querySelector('.video-modal');
      const videoFrame = videoModal?.querySelector('iframe');
      const closeVideo = videoModal?.querySelector('.video-close');

      document.querySelectorAll('.video-play').forEach((button) => {
        button.addEventListener('click', () => {
          const src = button.getAttribute('data-video') || '';
          if (videoFrame) videoFrame.setAttribute('src', `${src}?autoplay=1`);
          videoModal?.classList.add('is-open');
          videoModal?.setAttribute('aria-hidden', 'false');
        });
      });

      const closeModal = () => {
        videoModal?.classList.remove('is-open');
        videoModal?.setAttribute('aria-hidden', 'true');
        if (videoFrame) videoFrame.setAttribute('src', '');
      };

      closeVideo?.addEventListener('click', closeModal);
      videoModal?.addEventListener('click', (e) => {
        if (e.target === videoModal) closeModal();
      });

      // Image Lightbox Modal Action
      const imageModal = document.querySelector('.image-modal');
      const imageFrame = imageModal?.querySelector('img');
      const closeImage = imageModal?.querySelector('.image-close');

      document.querySelectorAll('.image-zoom-btn').forEach((button) => {
        button.addEventListener('click', () => {
          const src = button.getAttribute('data-image') || '';
          if (imageFrame) imageFrame.setAttribute('src', src);
          imageModal?.classList.add('is-open');
          imageModal?.setAttribute('aria-hidden', 'false');
        });
      });

      const closeImgModal = () => {
        imageModal?.classList.remove('is-open');
        imageModal?.setAttribute('aria-hidden', 'true');
        if (imageFrame) imageFrame.setAttribute('src', '');
      };

      closeImage?.addEventListener('click', closeImgModal);
      imageModal?.addEventListener('click', (e) => {
        if (e.target === imageModal) closeImgModal();
      });
    </script>

