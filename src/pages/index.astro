      .close-search {
        position: absolute;
        top: 30px;
        right: 30px;
        background: transparent;
        border: 0;
        color: var(--white);
        font-size: 30px;
        cursor: pointer;
      }

      /* Hero Section */
      .hero-area {
        padding: 0;
        background-color: var(--black);
        overflow: hidden;
      }

      .hero-slider {
        height: 720px;
        min-height: 720px;
      }

      .hero-slider:not(.swiper-initialized) .swiper-slide:not(:first-child) {
        display: none;
      }

      .hero-slider .swiper-slide {
        position: relative;
        display: flex;
        align-items: center;
        color: var(--white);
        overflow: hidden;
      }

      .slider-thumb {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        transform: scale(1.04);
        transition: transform 6000ms ease;
      }

      .swiper-slide-active .slider-thumb {
        transform: scale(1);
      }

      .slider-overlay {
        position: absolute;
        inset: 0;
        background:
          radial-gradient(circle at 72% 48%, rgba(255, 53, 20, 0.18), transparent 34%),
          linear-gradient(90deg, rgba(6, 11, 20, 0.74), rgba(6, 11, 20, 0.44)),
          rgba(6, 11, 20, 0.22);
        z-index: 2;
      }

      .slide-content-wrap {
        position: relative;
        z-index: 3;
        width: 100%;
        padding-top: 0;
      }

      .slide-text {
        max-width: 620px;
        margin: 0;
        text-align: left;
      }

      .slide-text h1,
      .slide-text p,
      .slide-btns {
        opacity: 0;
        visibility: hidden;
      }

      .swiper-slide-active .slide-text h1 {
        animation: slideInDown 800ms ease both;
        opacity: 1;
        visibility: visible;
      }

      .swiper-slide-active .slide-text p {
        animation: slideInRight 800ms ease both;
        animation-delay: 200ms;
        opacity: 1;
        visibility: visible;
      }

      .swiper-slide-active .slide-text .slide-btns {
        animation: slideInUp 800ms ease both;
        animation-delay: 400ms;
        opacity: 1;
        visibility: visible;
      }

      @keyframes slideInDown {
        from {
          transform: translateY(-40px);
          opacity: 0;
        }
        to {
          transform: translateY(0);
          opacity: 1;
        }
      }

      @keyframes slideInRight {
        from {
          transform: translateX(40px);
          opacity: 0;
        }
        to {
          transform: translateX(0);
          opacity: 1;
        }
      }

      @keyframes slideInUp {
        from {
          transform: translateY(40px);
          opacity: 0;
        }
        to {
          transform: translateY(0);
          opacity: 1;
        }
      }

      .slide-text h1 {
        font-family: var(--font-display);
        font-size: clamp(34px, 5vw, 58px);
        font-weight: 800;
        line-height: 1.04;
        margin-bottom: 18px;
      }

      .slide-text h1 strong {
        color: var(--yellow);
        display: block;
        font-size: clamp(54px, 8vw, 90px);
        text-transform: uppercase;
      }

      .slide-text p {
        font-size: 16px;
        color: rgba(255, 255, 255, 0.8);
        margin-bottom: 35px;
      }

      .slide-btns {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        gap: 25px;
      }

      .slide-btns .theme-btn {
        background-color: var(--yellow);
        color: var(--white);
        border-radius: 0;
        padding: 14px 28px;
      }

      .slide-btns .theme-btn:hover {
        background-color: var(--white);
        color: var(--black);
      }

      .video-play-btn {
        display: grid;
        width: 55px;
        height: 55px;
        border-radius: 999px;
        border: 2px solid var(--white);
        background: transparent;
        color: var(--white);
        place-items: center;
        place-items: center;
        cursor: pointer;
        font-size: 16px;
        transition: all 250ms ease;
      }

      .video-play-btn:hover {
        background-color: var(--yellow);
        border-color: var(--yellow);
        color: var(--black);
        transform: scale(1.05);
      }

      .hero-prev,
      .hero-next {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        z-index: 10;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 50px;
        height: 50px;
        background-color: rgba(255, 255, 255, 0.1);
        border: 0;
        color: var(--white);
        font-size: 20px;
        transition: all 250ms ease;
      }

      .hero-prev {
        left: 30px;
      }

      .hero-next {
        right: 30px;
      }

      .hero-prev:hover,
      .hero-next:hover {
        background-color: var(--yellow);
        color: var(--black);
      }

      .hero-prev::after,
      .hero-next::after {
        display: none !important;
      }

      :global(.swiper-button-prev::after),
      :global(.swiper-button-next::after) {
        display: none !important;
      }

      /* About Section */
      .about-area {
        background-color: var(--white);
        overflow: hidden;
        padding-top: 115px;
      }

      .about-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        align-items: center;
      }

      .about-image {
        position: relative;
      }

      .about-image img {
        width: 100%;
        aspect-ratio: 1 / 0.84;
        object-fit: cover;
        object-position: center center;
        border-radius: 0;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
      }

      .experience-badge {
        position: absolute;
        bottom: -28px;
        right: -24px;
        background-color: var(--yellow);
        color: var(--white);
        padding: 24px 30px;
        max-width: 238px;
        box-shadow: 0 15px 30px rgba(255, 53, 20, 0.24);
        border-radius: 0;
      }

      .exp-num {
        display: block;
        font-family: var(--font-display);
        font-size: 72px;
        font-weight: 800;
        line-height: 1;
        margin-bottom: 5px;
      }

      .exp-txt {
        font-family: var(--font-display);
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
        line-height: 1.25;
        display: block;
      }

      .about-info h2 {
        font-family: var(--font-display);
        font-size: clamp(30px, 4vw, 46px);
        font-weight: 800;
        line-height: 1.2;
        margin-bottom: 25px;
      }

      .about-info blockquote {
        border-left: 3px solid var(--yellow);
        padding-left: 26px;
        background: linear-gradient(90deg, rgba(255, 53, 20, 0.06), transparent 58%);
        padding-top: 18px;
        padding-bottom: 18px;
      }

      .about-info blockquote p {
        font-size: 15px;
        color: var(--ink-soft);
        margin-bottom: 18px;
        line-height: 1.8;
      }

      .about-info blockquote cite {
        font-style: normal;
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 13px;
        text-transform: uppercase;
      }

      .about-info blockquote cite strong {
        color: var(--yellow-hover);
      }

      .about-area .shape-bg {
        position: absolute;
        right: 0;
        bottom: 0;
        z-index: -1;
        opacity: 0.05;
        width: 35%;
      }

      /* Work With Us CTA Counter */
      .work-with-us-area {
        padding-top: 0;
        background-color: var(--white);
      }

      .work-with-us-area .content-box {
        background-color: #f7f8fb;
        border-radius: 0;
        padding: 50px 55px;
        border-bottom: 3px solid var(--yellow);
      }

      .cta-grid {
        display: grid;
        grid-template-columns: 1.2fr 1.8fr;
        gap: 50px;
        align-items: center;
      }

      .work-with-us-area h2 {
        font-family: var(--font-display);
        font-size: clamp(24px, 3.5vw, 36px);
        font-weight: 800;
        line-height: 1.25;
        margin: 8px 0 24px;
      }

      .facts-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 30px;
        text-align: center;
      }

      .fun-fact .timer {
        font-family: var(--font-display);
        font-size: 60px;
        font-weight: 800;
        color: var(--yellow);
        line-height: 1;
        margin-bottom: 10px;
      }

      .fun-fact .timer::after {
        content: "+";
        color: var(--ink);
        margin-left: 2px;
      }

      .fun-fact h4 {
        font-family: var(--font-display);
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--ink-soft);
        letter-spacing: 0.5px;
      }

      /* Services Tabs Area */
      .service-area {
        background-color: #f4f5f8;
        border-top: 1px solid #e7eaf0;
        border-bottom: 1px solid #e7eaf0;
      }

      .services-grid {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 50px;
        align-items: start;
        margin-top: 50px;
      }

      .services-nav .nav-pills {
        display: flex;
        flex-direction: column;
        gap: 12px;
      }

      .services-nav .nav-link {
        font-family: var(--font-display);
        background: var(--white);
        color: var(--ink);
        border: 1px solid var(--line);
        padding: 16px 24px;
        text-align: left;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 13px;
        display: flex;
        align-items: center;
        gap: 12px;
        cursor: pointer;
        border-radius: 0;
        transition: all 250ms ease;
      }

      .services-nav .nav-link i {
        color: var(--yellow);
        transition: transform 250ms ease;
      }

      .services-nav .nav-link:hover {
        border-color: var(--yellow);
      }

      .services-nav .nav-link:hover i {
        transform: translateX(3px);
      }

      .services-nav .nav-link.active {
        background-color: var(--yellow);
        color: var(--white);
        border-color: var(--yellow);
      }

      .services-nav .nav-link.active i {
        color: var(--white);
      }

      .services-content .tab-pane {
        display: none;
      }

      .services-content .tab-pane.active {
        display: block;
      }

      .tab-pane-grid {
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 40px;
        align-items: center;
        background-color: var(--white);
        padding: 50px;
        border-radius: 0;
        box-shadow: 0 18px 45px rgba(18, 20, 24, 0.08);
        border-bottom: 3px solid var(--yellow);
      }

      .tab-pane-grid .info h3 {
        font-family: var(--font-display);
        font-size: 24px;
        font-weight: 800;
        line-height: 1.35;
        margin-bottom: 18px;
      }

      .tab-pane-grid .info p {
        color: var(--ink-soft);
        font-size: 15px;
        margin-bottom: 24px;
      }

      .tab-pane-grid .thumb img {
        width: 100%;
        aspect-ratio: 4 / 3;
        object-fit: cover;
        border-radius: 0;
      }

      /* Work Process Area */
      .work-process-area {
        background-color: var(--white);
        background-image: url('/assets/img/bg.png');
        background-size: cover;
        background-position: center center;
        background-attachment: fixed;
        background-repeat: no-repeat;
      }

      .process-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 30px;
        margin-top: 50px;
      }

      @media (min-width: 768px) {
        .process-grid {
          grid-template-columns: repeat(2, 1fr);
        }
      }

      @media (min-width: 1024px) {
        .process-grid {
          grid-template-columns: repeat(3, 1fr);
        }
      }

      .work-process-area .process-item.item {
        border: 1px solid var(--line);
        padding: 50px;
        background-color: var(--white);
        position: relative;
        z-index: 1;
        overflow: hidden;
        transition: all 300ms ease;
      }

      .work-process-area .process-item.item:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.06);
      }

      .work-process-area .process-item.item i {
        display: inline-block;
        color: var(--yellow);
        font-size: 60px;
        margin-bottom: 25px;
      }

      .work-process-area .process-item.item h4 {
        position: relative;
        z-index: 1;
        line-height: 60px;
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 20px;
        margin-bottom: 15px;
      }

      .work-process-area .process-item.item h4 span {
        position: absolute;
        left: 0;
        top: 0;
        font-size: 80px;
        z-index: -1;
        color: #f4f4f4;
        opacity: 0.7;
        font-weight: 900;
        transition: all 300ms ease;
      }

      .work-process-area .process-item.item p {
        font-size: 14px;
        color: var(--ink-soft);
        line-height: 1.6;
        margin: 0;
      }

      /* Hover Background Number Animation */
      .work-process-area .process-item.item:hover h4 span {
        color: var(--yellow);
        opacity: 0.15;
      }

      /* Border Animations */
      .work-process-area .process-item.item::before, 
      .work-process-area .process-item.item::after {
        content: "";
        width: 0;
        height: 2px;
        position: absolute;
        transition: all 0.2s linear;
        background: var(--yellow);
      }

      .work-process-area .process-item.item .item-inner::before, 
      .work-process-area .process-item.item .item-inner::after {
        content: "";
        width: 2px;
        height: 0;
        position: absolute;
        transition: all 0.2s linear;
        background: var(--yellow);
      }

      .work-process-area .process-item.item:hover::before, 
      .work-process-area .process-item.item:hover::after {
        width: 100%;
      }

      .work-process-area .process-item.item:hover .item-inner::before, 
      .work-process-area .process-item.item:hover .item-inner::after {
        height: 100%;
      }

      .work-process-area .process-item.item::before, 
      .work-process-area .process-item.item::after {
        transition-delay: 0.2s;
      }

      .work-process-area .process-item.item .item-inner::before, 
      .work-process-area .process-item.item .item-inner::after {
        transition-delay: 0s;
      }

      .work-process-area .process-item.item::before {
        right: 0;
        top: 0;
      }

      .work-process-area .process-item.item::after {
        left: 0;
        bottom: 0;
      }

      .work-process-area .process-item.item .item-inner::before {
        left: 0;
        top: 0;
      }

      .work-process-area .process-item.item .item-inner::after {
        right: 0;
        bottom: 0;
      }

      .work-process-area .process-item.item:hover::before, 
      .work-process-area .process-item.item:hover::after {
        transition-delay: 0s;
      }

      .work-process-area .process-item.item:hover .item-inner::before, 
      .work-process-area .process-item.item:hover .item-inner::after {
        transition-delay: 0.2s;
      }

      /* Portfolio Area */
      .portfolio-area {
        background-color: var(--black);
      }

      .portfolio-box {
        margin-top: 50px;
        position: relative;
      }

      .portfolio-item {
        background-color: var(--dark-card);
        border-radius: 4px;
        overflow: hidden;
      }

      .portfolio-item .thumb {
        position: relative;
        overflow: hidden;
        aspect-ratio: 4 / 3;
      }

      .portfolio-item .thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 500ms ease;
      }

      .portfolio-item:hover .thumb img {
        transform: scale(1.05);
      }

      .portfolio-item .overlay {
        position: absolute;
        inset: 0;
        background-color: rgba(18, 20, 24, 0.7);
        display: grid;
        place-items: center;
        opacity: 0;
        transition: opacity 300ms ease;
      }

      .portfolio-item:hover .overlay {
        opacity: 1;
      }

      .image-zoom-btn {
        width: 50px;
        height: 50px;
        border-radius: 999px;
        border: 0;
        background-color: var(--yellow);
        color: var(--black);
        font-size: 16px;
        cursor: pointer;
        display: grid;
        place-items: center;
        transition: transform 250ms ease;
      }

      .image-zoom-btn:hover {
        transform: scale(1.1);
      }

      .portfolio-item .info {
        padding: 24px;
      }

      .portfolio-item .info h3 {
        font-family: var(--font-display);
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 6px;
        color: var(--white);
      }

      .portfolio-item .info h3 a:hover {
        color: var(--yellow);
      }

      .portfolio-item .info span {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.5);
        text-transform: uppercase;
        font-weight: 600;
        letter-spacing: 0.5px;
      }

      .portfolio-box {
        position: relative;
      }

      .portfolio-prev,
      .portfolio-next {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        width: 44px;
        height: 44px;
        background: transparent;
        border: 0;
        color: var(--yellow);
        font-size: 30px;
        cursor: pointer;
        z-index: 10;
        margin: 0;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 250ms ease;
      }

      .portfolio-prev {
        left: -50px;
      }

      .portfolio-next {
        right: -50px;
      }

      .portfolio-prev:hover,
      .portfolio-next:hover {
        color: var(--white);
      }

      .portfolio-prev::after,
      .portfolio-next::after {
        display: none !important;
      }

      @media (max-width: 1200px) {
        .portfolio-prev {
          left: 10px;
        }
        .portfolio-next {
          right: 10px;
        }
      }

      /* Team Section */
      .team-area {
        background-color: var(--white);
        overflow: hidden;
      }

      .team-items {
        margin-top: 50px;
      }

      .team-item {
        background-color: transparent;
        border-radius: 4px;
        overflow: visible;
      }

      .team-item .thumb {
        position: relative;
        overflow: hidden;
        aspect-ratio: 3 / 4;
      }

      .team-item .thumb::before {
        content: "";
        position: absolute;
        inset: 0;
        z-index: 1;
        background-image: linear-gradient(to bottom, rgba(18, 20, 24, 0.08), rgba(18, 20, 24, 0.82));
        opacity: 0;
        transition: opacity 650ms ease-in-out;
        pointer-events: none;
      }

      .team-item:hover .thumb::before {
        opacity: 1;
      }

      .team-item .thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .team-item .info {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        background-image: linear-gradient(to top, rgba(18, 20, 24, 0.9), transparent);
        padding: 80px 20px 72px;
        color: var(--white);
        z-index: 2;
        transition: opacity 650ms ease-in-out;
      }

      .team-item:hover .info {
        opacity: 0;
      }

      .team-item .info h4 {
        font-family: var(--font-display);
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 2px;
      }

      .team-item .info span {
        font-size: 13px;
        color: var(--yellow);
      }

      .team-item .overlay {
        position: absolute;
        left: 30px;
        right: 30px;
        bottom: 108px;
        z-index: 3;
        background-color: transparent;
        padding: 0;
        display: block;
        opacity: 0;
        transform: translateY(28px);
        transition: opacity 650ms ease-in-out, transform 650ms ease-in-out;
      }

      .team-item:hover .overlay {
        opacity: 1;
        transform: translateY(-34px);
      }

      .team-item .overlay h4 {
        font-family: var(--font-display);
        font-size: 20px;
        font-weight: 700;
        color: var(--white);
        margin-bottom: 12px;
      }

      .team-item .overlay p {
        font-size: 14px;
        color: rgba(255, 255, 255, 0.85);
        line-height: 1.6;
      }

      .team-item .social {
        position: relative;
        z-index: 4;
        width: calc(100% - 48px);
        min-height: 60px;
        margin: -30px auto 0;
        padding: 0 24px;
        background-color: var(--white);
        box-shadow: 0 10px 30px rgba(18, 20, 24, 0.08);
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .team-item .social ul {
        list-style: none;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 34px;
        width: 100%;
      }

      .team-item .social a {
        color: var(--ink);
        font-size: 17px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 22px;
        height: 22px;
      }

      .team-item .social a:hover {
        color: var(--yellow);
      }

      .team-items {
        position: relative;
        margin-top: 50px;
      }

      .team-items .row {
        display: grid;
        grid-template-columns: 1fr;
        gap: 30px;
      }

      @media (min-width: 768px) {
        .team-items .row {
          grid-template-columns: repeat(2, 1fr);
        }
      }

      @media (min-width: 1024px) {
        .team-items .row {
          grid-template-columns: repeat(3, 1fr);
        }
      }



      .team-area .fixed-shape {
        position: absolute;
        left: 0;
        bottom: 0;
        z-index: -1;
        opacity: 0.05;
        width: 25%;
      }

      /* Testimonials Section */
      .testimonials-area {
        background-color: var(--paper);
      }

      .testimonial-items-wrap {
        position: relative;
        z-index: 1;
      }

      .testimonial-items-wrap::after {
        position: absolute;
        left: 0;
        top: -15px;
        content: "\f10d";
        font-family: "Font Awesome 7 Free";
        font-weight: 600;
        font-size: 100px;
        line-height: 1;
        z-index: -1;
        opacity: 0.07;
        color: var(--ink);
      }

      .testimonial-grid {
        display: grid;
        grid-template-columns: 5fr 7fr;
        gap: 60px;
        align-items: center;
      }

      .title-column h2 {
        font-family: var(--font-display);
        font-size: clamp(32px, 4vw, 40px);
        font-weight: 800;
        line-height: 1.16;
        margin: 0 0 18px;
      }

      .title-column p {
        color: var(--ink-soft);
        font-size: 14px;
        line-height: 1.75;
        margin-bottom: 24px;
      }

      .testimonial-box {
        position: relative;
        z-index: 1;
        border-left: 2px solid var(--yellow);
        padding-left: 48px;
        overflow: hidden;
        min-width: 0;
      }

      .testimonial-item p {
        font-size: clamp(21px, 2.4vw, 27px);
        line-height: 1.58;
        font-style: italic;
        color: var(--ink);
        margin-bottom: 30px;
      }

      .testimonials-carousel {
        overflow: hidden;
        width: 100%;
        min-width: 0;
      }

      .testimonials-carousel .swiper-slide {
        height: auto;
        min-width: 0;
      }

      .testimonial-item {
        height: 100%;
      }

      .provider {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-top: 30px;
      }

      .provider .thumb img {
        width: 80px;
        height: 80px;
        border-radius: 999px;
        object-fit: cover;
      }

      .provider .info h5 {
        font-family: var(--font-display);
        font-size: 18px;
        font-weight: 600;
        margin-bottom: 7px;
        text-transform: capitalize;
      }

      .provider .info span {
        font-size: 14px;
        color: var(--yellow-hover);
        text-transform: uppercase;
        font-weight: 600;
        letter-spacing: 0.5px;
      }

      .testimonial-controls {
        text-align: left;
        margin-top: 30px;
        margin-left: 5px;
        margin-bottom: -8px;
        display: flex;
        gap: 15px;
      }

      .testimonial-prev,
      .testimonial-next {
        position: static;
        background: transparent;
        border: 0;
        color: var(--ink);
        font-size: 24px;
        margin: 0;
        padding: 0;
        cursor: pointer;
        width: auto;
        height: auto;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 250ms ease;
      }

      .testimonial-prev:hover,
      .testimonial-next:hover {
        color: var(--yellow);
      }

      .testimonial-prev::after,
      .testimonial-next::after {
        display: none !important;
      }

      /* Blog Area */
      .blog-area {
        background-color: var(--white);
      }

      .blog-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 30px;
        margin-top: 50px;
      }

      .blog-item {
        background-color: var(--white);
        border: 1px solid var(--line);
        border-radius: 4px;
        overflow: hidden;
        transition: all 300ms ease;
      }

      .blog-item:hover {
        transform: translateY(-6px);
        border-color: var(--yellow);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.05);
      }

      .blog-item .thumb {
        aspect-ratio: 16 / 10;
        overflow: hidden;
      }

      .blog-item .thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .blog-item .info {
        padding: 28px;
      }

      .blog-item .meta ul {
        list-style: none;
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 16px;
        font-size: 13px;
        color: var(--ink-soft);
      }

      .blog-item .meta a {
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .blog-item .meta img {
        width: 24px;
        height: 24px;
        border-radius: 999px;
      }

      .blog-item .meta i {
        color: var(--yellow);
      }

      .blog-item h3 {
        font-family: var(--font-display);
        font-size: 18px;
        font-weight: 700;
        line-height: 1.4;
        margin-bottom: 20px;
        min-height: 50px;
      }

      .blog-item h3 a:hover {
        color: var(--yellow);
      }

      /* Footer */
      .main-footer {
        background-color: var(--black);
        color: rgba(255, 255, 255, 0.7);
        padding: 0;
      }

      .footer-top {
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        padding: 60px 0;
      }

      .footer-top-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 30px;
      }

      .newsletter-form {
        display: flex;
        width: 100%;
        max-width: 500px;
        background-color: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 4px;
        padding: 4px;
      }

      .newsletter-form .form-control {
        flex: 1;
        background: transparent;
        border: 0;
        padding: 10px 16px;
        color: var(--white);
        outline: none;
      }

      .newsletter-form button {
        background-color: var(--yellow);
        color: var(--black);
        border: 0;
        width: 44px;
        height: 44px;
        border-radius: 4px;
        cursor: pointer;
        display: grid;
        place-items: center;
        transition: all 250ms ease;
      }

      .newsletter-form button:hover {
        background-color: var(--yellow-hover);
      }

      .footer-top .phone h4 {
        font-family: var(--font-display);
        color: var(--white);
        font-size: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .footer-top .phone i {
        color: var(--yellow);
      }

      .footer-middle-grid {
        display: grid;
        grid-template-columns: 1.5fr 1fr 1fr 1.5fr;
        gap: 40px;
        padding: 80px 15px;
      }

      .footer-col h4 {
        font-family: var(--font-display);
        color: var(--white);
        font-size: 16px;
        font-weight: 700;
        text-transform: uppercase;
        margin-bottom: 25px;
        letter-spacing: 0.5px;
      }

      .footer-col p {
        margin-bottom: 18px;
        font-size: 14px;
      }

      .footer-col ul {
        list-style: none;
      }

      .footer-col.contact li {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 12px;
        font-size: 14px;
      }

      .footer-col.contact i {
        color: var(--yellow);
      }

      .footer-col.link li {
        margin-bottom: 10px;
      }

      .footer-col.link a {
        font-size: 14px;
      }

      .footer-col.link a:hover {
        color: var(--yellow);
        padding-left: 4px;
      }

      .footer-col.opening-hours li {
        display: flex;
        justify-content: space-between;
        padding: 8px 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        font-size: 14px;
      }

      .footer-col.opening-hours li span {
        font-weight: 600;
      }

      .float-right.closed {
        color: #ff3333;
        font-weight: 700;
      }

      .footer-bottom {
        background-color: rgba(0, 0, 0, 0.2);
        padding: 24px 0;
        font-size: 13px;
      }

      .footer-bottom-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
      }

      .footer-bottom-inner a:hover {
        color: var(--yellow);
      }

      .footer-policy {
        list-style: none;
        display: flex;
        gap: 20px;
      }

      /* Scroll To Top */
      .scroll-top {
        position: fixed;
        right: 25px;
        bottom: 25px;
        z-index: 90;
        width: 50px;
        height: 50px;
        display: none;
        place-items: center;
        border: 0;
        border-radius: 4px;
        color: var(--black);
        background-color: var(--yellow);
        cursor: pointer;
        transition: all 250ms ease;
      }

      .scroll-top.is-visible {
        display: grid;
      }

      .scroll-top:hover {
        background-color: var(--yellow-hover);
        transform: translateY(-3px);
      }

      /* Modals */
      .video-modal,
      .image-modal {
        position: fixed;
        inset: 0;
        background-color: rgba(18, 20, 24, 0.95);
        backdrop-filter: blur(12px);
        z-index: 100;
        display: none;
        place-items: center;
        padding: 24px;
      }

      .video-modal.is-open,
      .image-modal.is-open {
        display: grid;
      }

      .video-modal iframe {
        width: min(960px, 92vw);
        aspect-ratio: 16 / 9;
        border: 0;
        background-color: var(--black);
        border-radius: 4px;
        box-shadow: 0 25px 50px rgba(0,0,0,0.5);
      }

      .image-modal img {
        max-width: min(960px, 92vw);
        max-height: 80vh;
        object-fit: contain;
        border-radius: 4px;
        box-shadow: 0 25px 50px rgba(0,0,0,0.5);
      }

      .video-close,
      .image-close {
        position: absolute;
        top: 30px;
        right: 30px;
        width: 44px;
        height: 44px;
        border-radius: 999px;
        background-color: var(--yellow);
        color: var(--black);
        border: 0;
        cursor: pointer;
        display: grid;
        place-items: center;
        font-size: 18px;
        transition: all 250ms ease;
      }

      .video-close:hover,
      .image-close:hover {
        background-color: var(--yellow-hover);
        transform: rotate(90deg);
      }

      /* Animations override to keep visible on fallbacks */
      html:not([data-wow-runtime="active"]) .wow {
        visibility: visible;
      }

      html[data-wow-runtime="active"] .wow {
        visibility: hidden;
      }

      .wow {
        animation-duration: 800ms;
      }

      /* Responsive Layout Rules */
      @media (max-width: 1024px) {
