        .main-header,
        .fixed-header {
          position: relative;
          top: auto;
          background-color: var(--white);
          border-bottom: 1px solid rgba(18, 20, 24, 0.08);
          box-shadow: 0 6px 18px rgba(18, 20, 24, 0.08);
        }

        .header-inner {
          grid-template-columns: auto 1fr auto;
          min-height: 58px;
          padding-top: 8px;
          padding-bottom: 8px;
        }

        .logo {
          grid-column: 2;
          grid-row: 1;
          justify-self: center;
        }

        .logo-display {
          display: none;
        }

        .logo-scrolled,
        .fixed-header .logo-scrolled {
          display: block;
        }

        .logo img {
          width: 132px;
        }

        .attr-nav {
          display: flex;
          grid-column: 3;
          grid-row: 1;
          justify-self: end;
          gap: 0;
        }

        .search-btn {
          display: none;
        }

        .attr-nav .theme-btn,
        .fixed-header .attr-nav .theme-btn {
          color: var(--ink);
          border-color: rgba(18, 20, 24, 0.16);
          padding: 8px 14px;
          font-size: 10px;
          line-height: 1;
          background-color: var(--white);
        }

        .menu-toggle {
          display: block;
          grid-column: 1;
          grid-row: 1;
          justify-self: start;
        }

        .menu-toggle span {
          background-color: var(--ink);
        }

        .main-menu {
          grid-column: 1 / -1;
          display: none;
          width: 100%;
          padding-top: 15px;
          background-color: var(--white);
        }

        .main-menu.is-open {
          display: block;
        }

        .navigation {
          flex-direction: column;
          gap: 0;
        }

        .navigation li {
          border-top: 1px solid rgba(18, 20, 24, 0.08);
        }

        .navigation a {
          display: block;
          padding: 12px 0;
          color: var(--ink);
        }

        .dropdown-menu {
          position: static !important;
          opacity: 1 !important;
          visibility: visible !important;
          transform: none !important;
          box-shadow: none !important;
          background-color: transparent !important;
          padding: 0 !important;
          display: none;
          border-left: 2px solid var(--yellow);
          margin-left: 15px !important;
          border-radius: 0 !important;
        }

        .dropdown.open > .dropdown-menu {
          display: block !important;
        }

        .dropdown-menu li a {
          color: rgba(31, 34, 41, 0.75) !important;
          padding: 8px 15px !important;
        }

        .dropdown-menu li a:hover {
          color: var(--yellow) !important;
          background-color: transparent !important;
          padding-left: 15px !important;
        }

        /* Megamenu mobile styles */
        .megamenu-fw > .dropdown-menu {
          padding: 0 !important;
        }

        .megamenu-fw .row {
          display: flex;
          flex-direction: column;
          margin: 0;
        }

        .col-menu {
          border-right: 0 !important;
          border-bottom: 1px solid rgba(18, 20, 24, 0.06);
          padding: 10px 0 !important;
        }

        .col-menu:last-child {
          border-bottom: 0;
        }

        .col-menu .title {
          color: var(--ink) !important;
          font-size: 13px !important;
          margin-bottom: 8px !important;
          padding-left: 15px;
        }

        .menu-col li a {
          color: rgba(31, 34, 41, 0.75) !important;
          padding: 6px 15px 6px 25px !important;
        }

        .menu-col li a:hover {
          color: var(--yellow) !important;
          padding-left: 25px !important;
        }

        .about-grid,
        .cta-grid,
        .services-grid,
        .tab-pane-grid,
        .process-grid,
        .testimonial-grid,
        .blog-grid,
        .footer-middle-grid {
          grid-template-columns: 1fr;
        }

        .footer-top-inner {
          flex-direction: column;
          text-align: center;
        }

        .about-grid,
        .services-grid,
        .tab-pane-grid,
        .process-grid,
        .testimonial-grid,
        .blog-grid,
        .footer-middle-grid {
          gap: 34px;
        }

        .work-with-us-area .content-box,
        .tab-pane-grid {
          padding: 40px;
        }

        .testimonial-box {
          border-left: 0;
          border-top: 2px solid var(--yellow);
          padding-left: 0;
          padding-top: 28px;
        }

        .testimonial-box::after {
          left: 0;
          top: 6px;
          font-size: 74px;
        }

        .testimonial-item p {
          font-size: 22px;
          line-height: 1.55;
        }

        .newsletter-form {
          margin: 0 auto;
        }

        .experience-badge {
          position: static;
          margin: 20px auto 0;
        }
      }

      @media (max-width: 768px) {
        section {
          padding: 58px 0;
        }

        .hero-slider {
          height: 540px;
          min-height: 540px;
        }

        .slide-text p {
          margin-bottom: 24px;
        }

        .slide-text {
          max-width: 100%;
          margin: 0 auto;
          padding: 0 20px;
          text-align: center;
        }

        .slide-text h1 {
