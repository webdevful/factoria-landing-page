        background: radial-gradient(circle at 30% 30%, rgba(18, 20, 24, 0.5), var(--black) 90%);
        z-index: 2;
      }

      .slide-content-wrap {
        position: relative;
        z-index: 3;
        width: 100%;
        padding-top: 80px;
      }

      .slide-text {
        max-width: 680px;
      }

      .slide-text h1,
      .slide-text p,
      .slide-btns {
        opacity: 0;
        visibility: hidden;
      }

      .swiper-slide-active .slide-text h1 {
        animation: slideInDown 800ms ease both;
        opacity: 1;
        visibility: visible;
      }

      .swiper-slide-active .slide-text p {
        animation: slideInRight 800ms ease both;
        animation-delay: 200ms;
        opacity: 1;
        visibility: visible;
      }

      .swiper-slide-active .slide-text .slide-btns {
        animation: slideInUp 800ms ease both;
        animation-delay: 400ms;
        opacity: 1;
        visibility: visible;
      }

      @keyframes slideInDown {
        from {
          transform: translateY(-40px);
          opacity: 0;
        }
        to {
          transform: translateY(0);
          opacity: 1;
        }
      }

      @keyframes slideInRight {
        from {
          transform: translateX(40px);
          opacity: 0;
        }
        to {
          transform: translateX(0);
          opacity: 1;
        }
      }

      @keyframes slideInUp {
        from {
          transform: translateY(40px);
          opacity: 0;
        }
        to {
          transform: translateY(0);
          opacity: 1;
        }
      }

      .slide-text h1 {
        font-family: var(--font-display);
        font-size: clamp(40px, 8vw, 75px);
        font-weight: 800;
        line-height: 1.1;
        margin-bottom: 20px;
      }

      .slide-text h1 strong {
        color: var(--yellow);
      }

      .slide-text p {
        font-size: 16px;
        color: rgba(255, 255, 255, 0.8);
        margin-bottom: 35px;
      }

      .slide-btns {
        display: flex;
        align-items: center;
        gap: 25px;
      }

      .video-play-btn {
        width: 55px;
        height: 55px;
        border-radius: 999px;
        border: 2px solid var(--white);
        background: transparent;
        color: var(--white);
        display: grid;
        place-items: center;
        cursor: pointer;
        font-size: 16px;
        transition: all 250ms ease;
      }

      .video-play-btn:hover {
        background-color: var(--yellow);
        border-color: var(--yellow);
        color: var(--black);
        transform: scale(1.05);
      }

      .hero-prev,
      .hero-next {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        z-index: 10;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 50px;
        height: 50px;
        background-color: rgba(255, 255, 255, 0.1);
        border: 0;
        color: var(--white);
        font-size: 20px;
        transition: all 250ms ease;
      }

      .hero-prev {
        left: 30px;
      }

      .hero-next {
        right: 30px;
      }

      .hero-prev:hover,
      .hero-next:hover {
        background-color: var(--yellow);
        color: var(--black);
      }

      .hero-prev::after,
      .hero-next::after {
        display: none !important;
      }

      :global(.swiper-button-prev::after),
      :global(.swiper-button-next::after) {
        display: none !important;
      }

      /* About Section */
      .about-area {
        background-color: var(--white);
        overflow: hidden;
      }

      .about-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        align-items: center;
      }

      .about-image {
        position: relative;
      }

      .about-image img {
        border-radius: 4px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
      }

      .experience-badge {
        position: absolute;
        bottom: -20px;
        right: -20px;
        background-color: var(--yellow);
        color: var(--black);
        padding: 30px;
        max-width: 250px;
        box-shadow: 0 15px 30px rgba(255, 182, 6, 0.35);
        border-radius: 4px;
      }

      .exp-num {
        display: block;
        font-family: var(--font-display);
        font-size: 55px;
        font-weight: 800;
        line-height: 1;
        margin-bottom: 5px;
      }

      .exp-txt {
        font-family: var(--font-display);
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
        line-height: 1.3;
        display: block;
      }

      .about-info h2 {
        font-family: var(--font-display);
        font-size: clamp(28px, 4vw, 42px);
        font-weight: 800;
        line-height: 1.2;
        margin-bottom: 25px;
      }

      .about-info blockquote {
        border-left: 4px solid var(--yellow);
        padding-left: 24px;
      }

      .about-info blockquote p {
        font-size: 15px;
        color: var(--ink-soft);
        margin-bottom: 18px;
        line-height: 1.8;
      }

      .about-info blockquote cite {
        font-style: normal;
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 13px;
        text-transform: uppercase;
      }

      .about-info blockquote cite strong {
        color: var(--yellow-hover);
      }

      .about-area .shape-bg {
        position: absolute;
        right: 0;
        bottom: 0;
        z-index: -1;
        opacity: 0.05;
        width: 35%;
      }

      /* Work With Us CTA Counter */
      .work-with-us-area {
        padding-top: 0;
        background-color: var(--white);
      }

      .work-with-us-area .content-box {
        background-color: var(--paper);
        border-radius: 4px;
        padding: 60px;
      }

      .cta-grid {
        display: grid;
        grid-template-columns: 1.2fr 1.8fr;
        gap: 50px;
        align-items: center;
      }

      .work-with-us-area h2 {
        font-family: var(--font-display);
        font-size: clamp(24px, 3.5vw, 36px);
        font-weight: 800;
        line-height: 1.25;
        margin: 8px 0 24px;
      }

      .facts-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 30px;
        text-align: center;
      }

      .fun-fact .timer {
        font-family: var(--font-display);
        font-size: 60px;
        font-weight: 800;
        color: var(--ink);
        line-height: 1;
        margin-bottom: 10px;
      }

      .fun-fact .timer::after {
        content: "+";
        color: var(--yellow);
        margin-left: 2px;
      }

      .fun-fact h4 {
        font-family: var(--font-display);
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--ink-soft);
        letter-spacing: 0.5px;
      }

      /* Services Tabs Area */
      .service-area {
        background-color: var(--paper);
      }

      .services-grid {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 50px;
        align-items: start;
        margin-top: 50px;
      }

      .services-nav .nav-pills {
        display: flex;
        flex-direction: column;
        gap: 12px;
      }

      .services-nav .nav-link {
        font-family: var(--font-display);
        background: var(--white);
        color: var(--ink);
        border: 1px solid var(--line);
        padding: 16px 24px;
        text-align: left;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 13px;
        display: flex;
        align-items: center;
        gap: 12px;
        cursor: pointer;
        border-radius: 4px;
        transition: all 250ms ease;
      }

      .services-nav .nav-link i {
        color: var(--yellow);
        transition: transform 250ms ease;
      }

      .services-nav .nav-link:hover {
        border-color: var(--yellow);
      }

      .services-nav .nav-link:hover i {
        transform: translateX(3px);
      }

      .services-nav .nav-link.active {
        background-color: var(--yellow);
        color: var(--black);
        border-color: var(--yellow);
      }

      .services-nav .nav-link.active i {
        color: var(--black);
      }

      .services-content .tab-pane {
        display: none;
      }

      .services-content .tab-pane.active {
        display: block;
      }

      .tab-pane-grid {
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 40px;
        align-items: center;
        background-color: var(--white);
        padding: 50px;
        border-radius: 4px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
      }

      .tab-pane-grid .info h3 {
        font-family: var(--font-display);
        font-size: 24px;
        font-weight: 800;
        line-height: 1.35;
        margin-bottom: 18px;
      }

      .tab-pane-grid .info p {
        color: var(--ink-soft);
        font-size: 15px;
        margin-bottom: 24px;
      }

      .tab-pane-grid .thumb img {
        border-radius: 4px;
