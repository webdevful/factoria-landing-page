      /* Work Process Area */
      .work-process-area {
        background-color: var(--white);
      }

      .process-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 40px;
        margin-top: 50px;
      }

      .process-item .item-inner {
        background-color: var(--white);
        border: 1px solid var(--line);
