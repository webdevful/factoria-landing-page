        }
      }

      @media (min-width: 768px) and (max-width: 1024px) {
        .process-grid {
          grid-template-columns: repeat(2, 1fr);
        }

        .blog-grid {
          grid-template-columns: repeat(2, 1fr);
        }

        .portfolio-area {
          background-color: var(--white);
        }

        .portfolio-area .section-header h2 {
          color: var(--ink);
