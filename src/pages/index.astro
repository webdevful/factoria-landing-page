      .title-column p {
        color: var(--ink-soft);
        font-size: 15px;
        margin-bottom: 30px;
      }

      .testimonial-box {
        background-color: var(--white);
        padding: 50px;
        border-radius: 4px;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.04);
      }

      .testimonial-item p {
        font-size: 17px;
        font-style: italic;
        color: var(--ink);
        line-height: 1.7;
        margin-bottom: 30px;
      }

      .provider {
        display: flex;
        align-items: center;
        gap: 16px;
      }

      .provider .thumb img {
        width: 60px;
        height: 60px;
        border-radius: 999px;
        object-fit: cover;
      }

      .provider .info h5 {
        font-family: var(--font-display);
        font-size: 16px;
        font-weight: 700;
        margin-bottom: 2px;
      }

      .provider .info span {
        font-size: 12px;
        color: var(--yellow-hover);
        text-transform: uppercase;
        font-weight: 600;
        letter-spacing: 0.5px;
      }

      .testimonial-controls {
        text-align: left;
        margin-top: 30px;
        margin-left: 5px;
        margin-bottom: -8px;
        display: flex;
        gap: 15px;
      }

      .testimonial-prev,
      .testimonial-next {
        position: static;
        background: transparent;
        border: 0;
        color: var(--ink);
        font-size: 24px;
        margin: 0;
        padding: 0;
        cursor: pointer;
        width: auto;
        height: auto;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 250ms ease;
      }

      .testimonial-prev:hover,
      .testimonial-next:hover {
        color: var(--yellow);
      }

      .testimonial-prev::after,
      .testimonial-next::after {
        display: none !important;
      }

      /* Blog Area */
      .blog-area {
        background-color: var(--white);
      }

      .blog-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 30px;
        margin-top: 50px;
      }

      .blog-item {
        background-color: var(--white);
        border: 1px solid var(--line);
        border-radius: 4px;
        overflow: hidden;
        transition: all 300ms ease;
      }

      .blog-item:hover {
        transform: translateY(-6px);
        border-color: var(--yellow);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.05);
      }

      .blog-item .thumb {
        aspect-ratio: 16 / 10;
        overflow: hidden;
      }

      .blog-item .thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .blog-item .info {
        padding: 28px;
      }

      .blog-item .meta ul {
        list-style: none;
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 16px;
        font-size: 13px;
        color: var(--ink-soft);
      }

      .blog-item .meta a {
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .blog-item .meta img {
        width: 24px;
        height: 24px;
        border-radius: 999px;
      }

      .blog-item .meta i {
        color: var(--yellow);
      }

      .blog-item h3 {
        font-family: var(--font-display);
        font-size: 18px;
        font-weight: 700;
        line-height: 1.4;
        margin-bottom: 20px;
        min-height: 50px;
      }

      .blog-item h3 a:hover {
        color: var(--yellow);
      }

      /* Sponsor clients area */
      .clients-area {
        background-color: var(--white);
        padding: 40px 0 95px;
      }

      .clients-box {
        border-top: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
        padding: 40px 0;
      }

      .client-item {
        display: grid;
        place-items: center;
        opacity: 0.6;
        transition: opacity 250ms ease;
      }

      .client-item:hover {
        opacity: 1;
      }

      /* Footer */
      .main-footer {
        background-color: var(--black);
        color: rgba(255, 255, 255, 0.7);
        padding: 0;
      }

      .footer-top {
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        padding: 60px 0;
      }

      .footer-top-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 30px;
      }

      .newsletter-form {
        display: flex;
        width: 100%;
        max-width: 500px;
        background-color: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 4px;
        padding: 4px;
      }

      .newsletter-form .form-control {
        flex: 1;
        background: transparent;
        border: 0;
        padding: 10px 16px;
        color: var(--white);
        outline: none;
      }

      .newsletter-form button {
        background-color: var(--yellow);
        color: var(--black);
        border: 0;
        width: 44px;
        height: 44px;
        border-radius: 4px;
        cursor: pointer;
        display: grid;
        place-items: center;
        transition: all 250ms ease;
      }

      .newsletter-form button:hover {
        background-color: var(--yellow-hover);
      }

      .footer-top .phone h4 {
        font-family: var(--font-display);
        color: var(--white);
        font-size: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .footer-top .phone i {
        color: var(--yellow);
      }

      .footer-middle-grid {
        display: grid;
        grid-template-columns: 1.5fr 1fr 1fr 1.5fr;
        gap: 40px;
        padding: 80px 15px;
      }

      .footer-col h4 {
        font-family: var(--font-display);
        color: var(--white);
        font-size: 16px;
        font-weight: 700;
        text-transform: uppercase;
        margin-bottom: 25px;
        letter-spacing: 0.5px;
      }

      .footer-col p {
        margin-bottom: 18px;
        font-size: 14px;
      }

      .footer-col ul {
        list-style: none;
      }

      .footer-col.contact li {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 12px;
        font-size: 14px;
      }

      .footer-col.contact i {
        color: var(--yellow);
      }

      .footer-col.link li {
        margin-bottom: 10px;
      }

      .footer-col.link a {
        font-size: 14px;
      }

      .footer-col.link a:hover {
        color: var(--yellow);
        padding-left: 4px;
      }

      .footer-col.opening-hours li {
        display: flex;
        justify-content: space-between;
        padding: 8px 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        font-size: 14px;
      }

      .footer-col.opening-hours li span {
        font-weight: 600;
      }

      .float-right.closed {
        color: #ff3333;
        font-weight: 700;
      }

      .footer-bottom {
        background-color: rgba(0, 0, 0, 0.2);
        padding: 24px 0;
        font-size: 13px;
      }

      .footer-bottom-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
      }

      .footer-bottom-inner a:hover {
        color: var(--yellow);
      }

      .footer-policy {
        list-style: none;
        display: flex;
        gap: 20px;
      }

      /* Scroll To Top */
      .scroll-top {
        position: fixed;
        right: 25px;
        bottom: 25px;
        z-index: 90;
        width: 50px;
        height: 50px;
        display: none;
        place-items: center;
        border: 0;
        border-radius: 4px;
        color: var(--black);
        background-color: var(--yellow);
        cursor: pointer;
        transition: all 250ms ease;
      }

      .scroll-top.is-visible {
        display: grid;
      }

      .scroll-top:hover {
        background-color: var(--yellow-hover);
        transform: translateY(-3px);
      }

      /* Modals */
      .video-modal,
      .image-modal {
        position: fixed;
        inset: 0;
        background-color: rgba(18, 20, 24, 0.95);
        backdrop-filter: blur(12px);
        z-index: 100;
        display: none;
        place-items: center;
        padding: 24px;
      }

      .video-modal.is-open,
      .image-modal.is-open {
        display: grid;
      }

      .video-modal iframe {
        width: min(960px, 92vw);
        aspect-ratio: 16 / 9;
        border: 0;
        background-color: var(--black);
        border-radius: 4px;
        box-shadow: 0 25px 50px rgba(0,0,0,0.5);
      }

      .image-modal img {
        max-width: min(960px, 92vw);
        max-height: 80vh;
        object-fit: contain;
        border-radius: 4px;
        box-shadow: 0 25px 50px rgba(0,0,0,0.5);
      }

      .video-close,
      .image-close {
        position: absolute;
        top: 30px;
        right: 30px;
        width: 44px;
        height: 44px;
        border-radius: 999px;
        background-color: var(--yellow);
        color: var(--black);
        border: 0;
        cursor: pointer;
        display: grid;
        place-items: center;
        font-size: 18px;
        transition: all 250ms ease;
      }

      .video-close:hover,
      .image-close:hover {
        background-color: var(--yellow-hover);
        transform: rotate(90deg);
      }

      /* Animations override to keep visible on fallbacks */
      .wow {
        visibility: visible !important;
        animation-duration: 800ms;
      }

      /* Responsive Layout Rules */
      @media (max-width: 1024px) {
        .header-inner {
          grid-template-columns: auto auto;
        }

        .attr-nav {
          display: none;
        }

        .menu-toggle {
          display: block;
        }

        .main-menu {
          grid-column: 1 / -1;
          display: none;
          width: 100%;
          padding-top: 15px;
        }

        .main-menu.is-open {
          display: block;
        }

        .navigation {
          flex-direction: column;
          gap: 0;
        }

        .navigation li {
          border-top: 1px solid rgba(255, 255, 255, 0.08);
        }

        .navigation a {
          display: block;
          padding: 12px 0;
        }

        .dropdown-menu {
          position: static !important;
          opacity: 1 !important;
          visibility: visible !important;
          transform: none !important;
          box-shadow: none !important;
          background-color: transparent !important;
          padding: 0 !important;
          display: none;
          border-left: 2px solid var(--yellow);
          margin-left: 15px !important;
          border-radius: 0 !important;
        }

        .dropdown.open > .dropdown-menu {
          display: block !important;
        }

        .dropdown-menu li a {
          color: rgba(255, 255, 255, 0.7) !important;
          padding: 8px 15px !important;
        }

        .dropdown-menu li a:hover {
          color: var(--yellow) !important;
          background-color: transparent !important;
          padding-left: 15px !important;
        }

        /* Megamenu mobile styles */
        .megamenu-fw > .dropdown-menu {
          padding: 0 !important;
        }

        .megamenu-fw .row {
          display: flex;
          flex-direction: column;
          margin: 0;
        }

        .col-menu {
          border-right: 0 !important;
          border-bottom: 1px solid rgba(255, 255, 255, 0.05);
          padding: 10px 0 !important;
        }

        .col-menu:last-child {
          border-bottom: 0;
        }

        .col-menu .title {
          color: var(--white) !important;
          font-size: 13px !important;
          margin-bottom: 8px !important;
          padding-left: 15px;
        }

        .menu-col li a {
          color: rgba(255, 255, 255, 0.7) !important;
          padding: 6px 15px 6px 25px !important;
        }

        .menu-col li a:hover {
          color: var(--yellow) !important;
          padding-left: 25px !important;
        }

        .about-grid,
        .cta-grid,
        .services-grid,
        .tab-pane-grid,
        .process-grid,
        .testimonial-grid,
        .blog-grid,
        .footer-middle-grid {
          grid-template-columns: 1fr;
        }

        .footer-top-inner {
          flex-direction: column;
          text-align: center;
        }

        .newsletter-form {
          margin: 0 auto;
        }

        .experience-badge {
          position: static;
          margin: 20px auto 0;
        }
      }

      @media (max-width: 768px) {
        .header-top {
          display: none;
        }

        .top-left {
          flex-direction: column;
          gap: 8px;
        }

        .facts-grid {
          grid-template-columns: 1fr;
        }

        .footer-bottom-inner {
          flex-direction: column;
          text-align: center;
        }

        .footer-policy {
          justify-content: center;
        }
      }
    </style>
  </body>
</html>
