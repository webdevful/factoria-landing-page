  "sourceFacts": [
    "The Fatory Team Members source card keeps the social links inside a white horizontal bar that overlaps the lower part of each image card.",
    "The social bar is not a loose icon row below the card and does not replace Font Awesome social icons with generated art.",
    "The Fatory Team Members heading has red divider pseudo-elements under the H2: a 40px line plus a short 5px segment.",
    "The Fatory Team Members hover does not snap to a fast full-card blackout; member info fades with slower ease-in-out timing while the overlay text slides upward over the darkened image."
  ],
  "checks": [
    {
      "selector": ".team-area .section-header h2",
      "declarations": {
        "position": "relative",
        "display": "table",
        "padding-bottom": "28px"
      }
    },
    {
      "selector": ".team-area .section-header h2::before",
      "declarations": {
        "content": "\"\"",
        "position": "absolute",
        "width": "40px",
        "height": "2px",
        "background-color": "var(--yellow)"
      }
    },
    {
      "selector": ".team-area .section-header h2::after",
      "declarations": {
        "content": "\"\"",
        "position": "absolute",
        "width": "5px",
        "height": "2px",
        "background-color": "var(--yellow)"
      }
    },
    {
      "selector": ".team-item .thumb::before",
      "declarations": {
        "content": "\"\"",
        "position": "absolute",
        "opacity": "0",
        "transition": "opacity 650ms ease-in-out"
      }
    },
    {
      "selector": ".team-item .info",
      "declarations": {
        "z-index": "2",
        "transition": "opacity 650ms ease-in-out"
      }
    },
    {
      "selector": ".team-item .overlay",
      "declarations": {
        "background-color": "transparent",
        "display": "block",
        "opacity": "0",
        "transform": "translateY(28px)",
        "transition": "opacity 650ms ease-in-out, transform 650ms ease-in-out"
      }
    },
    {
      "selector": ".team-item .social",
      "declarations": {
        "position": "relative",
        "z-index": "4",
        "background-color": "var(--white)",
        "display": "flex",
        "align-items": "center",
        "justify-content": "center"
      }
    },
    {
      "selector": ".team-item .social ul",
      "declarations": {
        "display": "flex",
        "justify-content": "center",
        "align-items": "center"
      }
    },
    {
      "selector": ".team-item .social a",
      "declarations": {
        "display": "inline-flex",
        "align-items": "center",
        "justify-content": "center"
      }
    }
  ],
  "forbidden": [
